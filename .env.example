# App — URL pública (redirects Supabase Auth em produção)
# VITE_APP_URL=https://seu-dominio.com

# PostHog — chave de projeto (ok no bundle do cliente)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase — SOMENTE anon key no app Capacitor (Fase 11)
# Obtenha em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NUNCA colocar no .env local com prefixo VITE_:
# - SUPABASE_SERVICE_ROLE_KEY
# - JWT secret
# - Database password
# Service role fica só em Edge Functions / CI (sem VITE_ / EXPO_PUBLIC_)
